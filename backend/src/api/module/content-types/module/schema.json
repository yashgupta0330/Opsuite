{
  "kind": "collectionType",
  "collectionName": "modules",
  "info": {
    "singularName": "module",
    "pluralName": "modules",
    "displayName": "Modules",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "shortDescription": {
      "type": "text"
    },
    "category": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "Core Capabilities",
        "Technology & Infrastructure"
      ]
    },
    "themeColor": {
      "type": "enumeration",
      "default": "Brand",
      "enum": [
        "Brand",
        "Orange",
        "Purple",
        "Yellow"
      ]
    },
    "rank": {
      "type": "integer",
      "default": 100
    },
    "sections": {
      "type": "dynamiczone",
      "components": [
        "sections.hero",
        "sections.feature-highlights",
        "sections.side-feature",
        "sections.feature-grid",
        "sections.numbered-benefits",
        "sections.testimonial-banner",
        "sections.contact-section",
        "sections.advantage-section",
        "sections.detailed-features",
        "sections.impact-section"
      ]
    }
  }
}
